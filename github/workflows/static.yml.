name: Deploy to GitHub Pages

on:
  push:
    branches:
      - main

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v4
      
      - name: List Directory Structure (للكشف عن مكان الملفات)
        run: ls -R
      
      - name: Install and Build
        run: |
          npm install
          npm run build
          
      - name: Upload Artifacts
        uses: actions/upload-pages-artifact@v3
        with:
          # إذا فشل النشر، سنغير هذا المسار إلى 'dist' أو '.'
          path: 'build'

  deploy:
    needs: build
    runs-on: ubuntu-latest
    permissions:
      pages: write
      id-token: write
    environment:
      name: github-pages
      url: ${{ steps.deployment.outputs.page_url }}
    steps:
      - name: Deploy
        id: deployment
        uses: actions/deploy-pages@v4
